<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".EditRecipe">

    <TextView
        android:id="@+id/textView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="50dp"
        android:text="Edit your Recipe"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold|italic" />

    <EditText
        android:id="@+id/ed_title_ed"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginStart="10dp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="10dp"
        android:layout_marginRight="10dp"
        android:background="@drawable/shape1"
        android:ems="10"
        android:hint="Enter the title "
        android:inputType="text"
        android:textAlignment="center" />

    <EditText
        android:id="@+id/ed_ingre_ed"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:background="@drawable/shape1"

        android:hint="enter the ingredients"
        android:padding="20dp"
        android:textAlignment="center" />

    <EditText
        android:id="@+id/ed_step_ed"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:background="@drawable/shape1"
        android:hint="enter your step"
        android:padding="20dp"
        android:textAlignment="center" />

    <EditText
        android:id="@+id/ed_cate_ed"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:background="@drawable/shape1"
        android:ems="10"
        android:hint="enter the category"

        android:textAlignment="center" />

    <EditText
        android:id="@+id/ed_url_ed"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        android:background="@drawable/shape1"
        android:ems="10"
        android:hint="enter the url "
        android:inputType="text"
        android:padding="20dp"
        android:textAlignment="center" />

    <Button
        android:id="@+id/bt_up"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:backgroundTint="#009688"
        android:text="Edit" />

</LinearLayout>
