<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFDFD"
    tools:context=".Recipedetails">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/img_recipe_details"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/o2" />

        <LinearLayout
            android:id="@+id/owner_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible">

            <ImageButton
                android:id="@+id/btn_edit_recipe"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/circle_bg_semi_transparent"
                android:contentDescription="Edit Recipe"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btn_delete_recipe"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_bg_semi_transparent"
                android:contentDescription="Delete Recipe"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/white" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_title_details"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:text="Recipe Title"
            android:textColor="#333333"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/img_recipe_details" />

        <TextView
            android:id="@+id/tv_category_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/card"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Category"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_title_details" />

        <TextView
            android:id="@+id/tv_source_url"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:autoLink="web"
            android:text="Source Link"
            android:textColor="@color/purple_500"
            android:textSize="14sp"
            android:textStyle="italic"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/tv_title_details"
            app:layout_constraintStart_toStartOf="@+id/tv_title_details"
            app:layout_constraintTop_toBottomOf="@+id/tv_category_details"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/label_ingredients"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Ingredients"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/tv_title_details"
            app:layout_constraintTop_toBottomOf="@+id/tv_source_url" />

        <ScrollView
            android:id="@+id/scroll_ingredients"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constrainedHeight="true"
            app:layout_constraintHeight_max="180dp"
            app:layout_constraintEnd_toEndOf="@+id/tv_title_details"
            app:layout_constraintStart_toStartOf="@+id/tv_title_details"
            app:layout_constraintTop_toBottomOf="@+id/label_ingredients">

            <TextView
                android:id="@+id/tv_ingredients_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="• Ingredient 1\n• Ingredient 2"
                android:textColor="#666666"
                android:textSize="16sp" />
        </ScrollView>

        <TextView
            android:id="@+id/label_steps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Steps"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/tv_title_details"
            app:layout_constraintTop_toBottomOf="@+id/scroll_ingredients" />

        <ScrollView
            android:id="@+id/scroll_steps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constrainedHeight="true"
            app:layout_constraintHeight_max="180dp"
            app:layout_constraintEnd_toEndOf="@+id/tv_title_details"
            app:layout_constraintStart_toStartOf="@+id/tv_title_details"
            app:layout_constraintTop_toBottomOf="@+id/label_steps">

            <TextView
                android:id="@+id/tv_steps_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="1. Step one\n2. Step two"
                android:textColor="#666666"
                android:textSize="16sp" />
        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
